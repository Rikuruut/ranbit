{
  "expo": {
    "name": "Ranbit",
    "slug": "ranbit",
    "version": "0.1.3-alpha",
    "orientation": "portrait",
    "scheme": "ranbit",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ranbit.app"
    },
    "android": {
      "package": "com.ranbit.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
